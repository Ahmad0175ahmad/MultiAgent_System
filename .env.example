# =========================
# LLM CONFIGURATION
# =========================

# Groq: Free API at console.groq.com
# Current models: llama-3.1-70b-versatile, mixtral-8x7b-32768, gemma-7b-it
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini: Get key from ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

DEFAULT_LLM_PROVIDER=groq


# =========================
# EXTERNAL TOOLS
# =========================

# Tavily Search: Get key from tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# =========================
# STORAGE PATHS
# =========================

CHROMADB_PATH=./data/chroma_db
UPLOADS_PATH=./data/uploads
SESSIONS_DB_PATH=./data/sessions.db

# =========================
# FASTAPI SERVER CONFIG
# =========================

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
DEBUG=True
